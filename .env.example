# ── Client-side (safe to expose; bundled into the browser) ──
# EmailJS public credentials are designed to be public.
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ── Server-side ONLY (used by /api/ask.js — never prefix with VITE_) ──
# WARNING: A VITE_-prefixed key is embedded in client JS and publicly readable.
# Keep the Groq key server-side. Set this in your Vercel project env vars.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
